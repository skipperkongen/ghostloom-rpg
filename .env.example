# Secret key for encrypting/decrypting state tokens
# This is REQUIRED for the service to work
# Generate a secure 32-byte key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or using base64 encoding:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
STATE_SECRET_KEY=

# Placeholder for future LLM API integration
# Optional in v1 - not used by the stub LLM implementation
# When integrating a real LLM (OpenAI, Anthropic, etc.), set this to your API key
LLM_API_KEY=
