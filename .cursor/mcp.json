{
    "mcpServers": {
      "supabase": {
        "command": "./node_modules/.bin/mcp-server-supabase",
        "args": [
          "--read-only",
          "--project-ref=${SUPABASE_PROJECT_REF}"
        ],
        "env": {
          "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
        }
      }
    }
  }
  