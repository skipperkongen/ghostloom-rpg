meta {
  name: Register
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "player@example.com",
    "password": "password123",
    "display_name": "Player"
  }
}

script:post-response {
  bru.setVar("token", res.body.access_token);
}
